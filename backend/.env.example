# Base de datos (Supabase)
# IMPORTANTE: usar el Session Pooler (IPv4). La conexión directa db.xxx.supabase.co
# es solo IPv6 y no enruta en muchas redes. Tomar el string de:
#   Supabase -> Project Settings -> Database -> Connection string -> "Session pooler"
# y reemplazar el prefijo por postgresql+asyncpg://
DATABASE_URL=postgresql+asyncpg://postgres.PROJECT_REF:PASSWORD@aws-1-us-east-1.pooler.supabase.com:5432/postgres

# Redis
REDIS_URL=redis://localhost:6379/0

# Meta / WhatsApp
META_APP_ID=
META_APP_SECRET=
META_WEBHOOK_VERIFY_TOKEN=ventasbot_webhook_token_aqui

# LLM (proveedor compatible con la API de OpenAI)
# Desarrollo: Groq es gratis y sin tarjeta -> https://console.groq.com
#   LLM_BASE_URL=https://api.groq.com/openai/v1
#   LLM_MODEL=openai/gpt-oss-120b   (maneja tool-calling de forma confiable)
# Producción: OpenAI
#   LLM_BASE_URL=https://api.openai.com/v1
#   LLM_MODEL=gpt-4o-mini
LLM_API_KEY=
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_MODEL=openai/gpt-oss-120b

# Supabase
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# dLocal (pagos). Sin credenciales, el bot genera un QR SIMULADO para pruebas.
DLOCAL_API_KEY=
DLOCAL_SECRET_KEY=
DLOCAL_SANDBOX=true
DLOCAL_NOTIFICATION_URL=

# App
APP_ENV=development
SECRET_KEY=cambia_esto_en_produccion
